        "progress_bar = tqdm(range(len(data)))\n",
        "\n",
        "for sample in data:\n",
        "    prompt = build_prompt(\n",
        "        sample[\"text\"],\n",
        "        topic=sample[\"tag\"],\n",
        "        data_dict=data_dict,\n",
        "        n_examples=2\n",
        "    )\n",
        "    sample_output = inference(prompt)   # новая функция\n",
        "    train_output.append(sample_output)\n",
        "    progress_bar.update(1)"
